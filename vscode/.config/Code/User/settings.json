{
	"files.trimFinalNewlines": true,
	"files.insertFinalNewline": true,
	"editor.insertSpaces": true,
	"editor.renderWhitespace": "all",
	"editor.suggestSelection": "first",
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
	"editor.minimap.enabled": false,
	"files.eol": "\n",
	"code-eol.newlineCharacter": "¬",
	"code-eol.returnCharacter": "¤",
	"code-eol.crlfCharacter": "¤¬",
	"workbench.iconTheme": "vs-minimal",
	"editor.fontFamily": "'Fira Code', Consolas",
	"editor.fontSize": 17,
	"editor.fontLigatures": true,
	"terminal.integrated.fontFamily": "'Iosevka Nerd Font Mono', 'Fira Code', Consolas",
	"terminal.integrated.fontSize": 16,
	"explorer.confirmDelete": false,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"javascript.updateImportsOnFileMove.enabled": "always",
	"cSpell.userWords": [
		"astralbody",
		"autobind",
		"booru",
		"boorus",
		"capti",
		"Captify",
		"Codespaces",
		"Danbooru",
		"deque",
		"donmai",
		"dotfiles",
		"Dotlet",
		"dotlets",
		"failable",
		"Folgezettel",
		"Formik",
		"formikable",
		"gelbooru",
		"GNEWS",
		"isize",
		"jwks",
		"Kaizen",
		"Keyphrase",
		"Keyphrases",
		"Luhmann",
		"middlewares",
		"minigrep",
		"nanos",
		"pacman",
		"Pubmatic",
		"Safebooru",
		"Seedword",
		"SEEDWORDS",
		"shellcheck",
		"shellformat",
		"Tampermonkey",
		"testid",
		"Tetris",
		"unfetch",
		"unformat",
		"userscript",
		"Userscripts",
		"usize",
		"xandr",
		"zettelkasten"
	],
	"explorer.confirmDragAndDrop": false,
	// "files.autoSave": "afterDelay",
	"gitlens.remotes": [
		{
			"domain": "captify",
			"type": "Custom",
			"name": "Captify",
			"protocol": "https",
			"urls": {
				"repository": "https://github.com/${repo}",
				"branches": "https://github.com/${repo}/branches",
				"branch": "https://github.com/${repo}/commits/${branch}",
				"commit": "https://github.com/${repo}/commit/${id}",
				"file": "https://github.com/${repo}?path=${file}${line}",
				"fileInBranch": "https://github.com/${repo}/blob/${branch}/${file}${line}",
				"fileInCommit": "https://github.com/${repo}/blob/${id}/${file}${line}",
				"fileLine": "#L${line}",
				"fileRange": "#L${start}-L${end}"
			}
		}
	],
	"gitlens.codeLens.enabled": false,
	"git.autofetch": true,
	"editor.bracketPairColorization.enabled": true,
	"redhat.telemetry.enabled": false,
	"javascript.validate.enable": false,
	"workbench.editor.untitled.hint": "hidden",
	"gitlens.advanced.messages": {
		"suppressGitMissingWarning": true
	},
	"[python]": {
		"editor.tabSize": 4,
		"editor.formatOnPaste": false,
		"editor.formatOnSaveMode": "file"
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"files.trimTrailingWhitespace": true,
	"files.associations": {
		"*.py": "python",
		".gitconfig": "plaintext",
		".gitconfig_captify": "plaintext",
		"gitconfig": "plaintext"
	},
	"python.formatting.provider": "black",
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "modificationsIfAvailable",
	//"editor.formatOnSaveMode": "file",
	"markdown.experimental.validate.enabled": true,
	"shellcheck.enable": true,
	"shellcheck.enableQuickFix": true,
	"shellcheck.run": "onSave",
	"shellcheck.exclude": [],
	"git.ignoreMissingGitWarning": true,
	"editor.codeActionsOnSave": {
		"source.fixAll": true,
		"source.fixAll.shellcheck": true
	},
	"typescript.suggest.paths": false,
	"javascript.suggest.paths": false,
	"shellformat.useEditorConfig": true,
	"editor.stickyScroll.enabled": true,
	"window.zoomLevel": 1,
	"[dockerfile]": {
		"editor.defaultFormatter": "ms-azuretools.vscode-docker"
	}
}
